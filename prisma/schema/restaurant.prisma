// =========================
// RESTAURANT
// =========================

model Restaurant {
  id           String  @id @default(cuid())
  name         String?
  location     String?
  geoLocation  String?
  latitude     Float?
  longitude    Float?
  logoUrl      String?
  logoId       String?
  logo         File?   @relation("RestaurantLogo", fields: [logoId], references: [id])
  menuImageUrl String?
  menuImageId  String?
  menuImage    File?   @relation("RestaurantMenuImage", fields: [menuImageId], references: [id])

  rating Float?

  noiselevel   String?
  privacylevel String?

  status String @default("DRAFT")

  // JSON for tracking origin: { source: "TELEGRAM" | "PUBLIC_USER", specificSource: string, metadata: any }
  sourceInfo Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  menuItems      RestaurantMenu[]
  features       RestaurantFeatureAssignment[]
  imageLibrary   RestaurantImageLibrary[]
  userFeedbacks  UserFeedback[]

  @@schema("restaurant")
}

// =========================
// FEATURES (WIFI, PARKING, etc.)
// =========================

model Feature {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments RestaurantFeatureAssignment[]

  @@schema("restaurant")
}

model RestaurantFeatureAssignment {
  id           String @id @default(cuid())
  restaurantId String
  featureId    String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  feature    Feature    @relation(fields: [featureId], references: [id])

  @@unique([restaurantId, featureId])
  @@schema("restaurant")
}

model RestaurantImageLibrary {
  id String @id @default(cuid())

  restaurantId           String
  imageId                String
  sourceRestaurantMenuId String?
  usageType              ImageUsage @default(GENERAL)

  restaurant           Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  image                File            @relation(fields: [imageId], references: [id], onDelete: Cascade)
  sourceRestaurantMenu RestaurantMenu? @relation("RestaurantImageLibrarySource", fields: [sourceRestaurantMenuId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, imageId])
  @@index([restaurantId, updatedAt])
  @@schema("restaurant")
}

// =========================
// USER FEEDBACK / EDIT SUGGESTIONS
// =========================

enum ImageUsage {
  LOGO
  MENU
  MEAL
  GENERAL

  @@schema("restaurant")
}

enum FeedbackType {
  MEAL_INFO
  MENU_IMAGES

  @@schema("restaurant")
}

enum FeedbackStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("restaurant")
}

model UserFeedback {
  id String @id @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  // Optional: If feedback is for a specific meal
  restaurantMenuId String?
  restaurantMenu   RestaurantMenu? @relation(fields: [restaurantMenuId], references: [id])

  type   FeedbackType
  status FeedbackStatus @default(PENDING)

  // MEAL_INFO specific
  suggestedPrice           Float?
  suggestedPortionSize     String? // Using String instead of Enum to avoid cross-schema enum complexity, or we can use the exact PortionSize if we import it. String is safer for raw suggestions.
  suggestedPreparationTime Int?

  // MENU_IMAGES specific
  // Store an array of uploaded image URLs or IDs. Since it's temporary, URLs or basic strings are easiest.
  uploadedImageUrls String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("restaurant")
}
