// =========================
// RESTAURANT
// =========================

model Restaurant {
  id           String  @id @default(cuid())
  name         String?
  location     String?
  geoLocation  String?
  logoUrl      String?
  logoId       String?
  logo         File?   @relation("RestaurantLogo", fields: [logoId], references: [id])
  menuImageUrl String?
  menuImageId  String?
  menuImage    File?   @relation("RestaurantMenuImage", fields: [menuImageId], references: [id])

  rating Float?

  noiselevel   String?
  privacylevel String?

  status String @default("DRAFT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  menuItems RestaurantMenu[]
  features  RestaurantFeatureAssignment[]
}

// =========================
// FEATURES (WIFI, PARKING, etc.)
// =========================

model Feature {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments RestaurantFeatureAssignment[]
}

model RestaurantFeatureAssignment {
  id           String @id @default(cuid())
  restaurantId String
  featureId    String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  feature    Feature    @relation(fields: [featureId], references: [id])

  @@unique([restaurantId, featureId])
}
