// =========================
// ENUMS
// =========================

enum DietaryCategory {
  YETSOM
  YEFITSIK

  @@schema("public")
}

enum FoodCategoryType {
  FOOD
  DRINK
  EXTRA

  @@schema("public")
}

enum MenuCategory {
  MEAL
  DRINK
  SIDES

  @@schema("public")
}

enum PortionSize {
  ONE_PERSON
  TWO_PEOPLE
  THREE_PEOPLE
  FAMILY

  @@schema("public")
}

// =========================
// CATEGORY (GLOBAL GROUPING)
// =========================
// Simple top-level grouping: "Seafood", "Ethiopian", "Fast Food", "Drinks", etc.

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  sortOrder   Int?
  isActive    Boolean @default(true)

  menuItems MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("menu")
}

// =========================
// GLOBAL MENU ITEM (ABSTRACT FOOD)
// =========================

model MenuItem {
  id          String  @id @default(cuid())
  name        String // e.g. "Burger", "Shiro", "Pizza"
  description String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  type MenuCategory?

  tags String[] // ["fast-food", "ethiopian", "popular"]

  // 🔥 Aggregated analytics (NOT source of truth)
  avgPrice   Float?
  minPrice   Float?
  maxPrice   Float?
  priceCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imageId String?
  image   File?   @relation(fields: [imageId], references: [id])

  restaurants RestaurantMenu[]

  @@schema("menu")
}

// =========================
// RESTAURANT-SPECIFIC MENU (REAL DATA)
// =========================

model RestaurantMenu {
  id String @id @default(cuid())

  restaurantId String
  menuItemId   String

  // 🔥 REAL restaurant-specific overrides (The actual meal name)
  name        String? // e.g. "Double Beef Destroyer" 
  description String? // restaurant-specific description

  // Restaurant-specific properties
  foodCategoryType FoodCategoryType?
  dietaryCategory  DietaryCategory?
  price            Float
  portionSize     PortionSize?
  spicyLevel      Int? // 0–5 scale
  preparationTime Int? // minutes

  ingredients String[] // restaurant-specific recipe
  calories    Int?

  isAvailable Boolean @default(true)

  // UX / discovery improvements
  isPopular     Boolean @default(false)
  isRecommended Boolean @default(false)

  imageId  String? // New robust image reference
  image    File?   @relation(fields: [imageId], references: [id])
  imageUrl String? // Keep for migration if needed

  sortOrder Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id])

  @@index([restaurantId, menuItemId])
  @@schema("menu")
}
